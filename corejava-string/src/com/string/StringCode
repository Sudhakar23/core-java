import java.util.ArrayList;
import java.util.StringTokenizer;

class LIFOStack {
   private char[ ] stack;
   private int stackPointer;

   public LIFOStack( int stackSize ) {
       stack = new char[ stackSize ];
       stackPointer = -1;
   }

   public void push( char ch ) {
      stack[ ++stackPointer ] = ch;
   }

   public char pop( ) {
       return stack[ stackPointer-- ];
   }

   public char peek( ) {
       return stack[ stackPointer ];
   }

   public boolean stackIsEmpty( ) {
      return ( stackPointer == -1 );
   }
} 

class Reverser {
   private String inputString;                
   private String outputString;               

   public Reverser( String inputString ) { 
       this.inputString = inputString; 
   }

   public String reverse( ) {
      outputString = "";
      ArrayList< String > inputSubstringsList = new ArrayList< String >( );

      StringTokenizer stringTokenizer = new StringTokenizer( inputString, " ", true );
      while( stringTokenizer.hasMoreElements( ) ) {
          inputSubstringsList.add( stringTokenizer.nextElement().toString() );
      }

      int stackCounter = inputSubstringsList.size();

      ArrayList< LIFOStack > stacks = new ArrayList< LIFOStack >( );
      for( int i = 0; i < stackCounter; i++ ) {
          stacks.add(new LIFOStack( inputSubstringsList.get( i ).length( ) ) );

          for( int j = 0; j < inputSubstringsList.get( i ).length( ); j++ ) {
              char ch = inputSubstringsList.get( i ).charAt( j );     
              stacks.get( i ).push( ch );             
          }

          while( !stacks.get( i ).stackIsEmpty( ) ) {
              char ch = stacks.get( i ).pop( );      
              outputString = outputString + ch;          
          }
      } 
      return outputString;
   }  
}  

class ReverseApplication {
   private static Reverser reverser;    
   public static void main( String... args ) {

      reverser = new Reverser( "olleH dlroW" );
      System.out.println( reverser.reverse( ) );

      reverser = new Reverser( "Hello World" );
      System.out.println( reverser.reverse( ) );
   }  
}  
